function getBalance() {
    return document.getElementById("balance-value").innerText;
}
function printBalance(num) {
    document.getElementById("balance-value").innerText = num;
}
function getAmount() {
    return document.getElementById("amount-value").innerText;
}
function printAmount(num) {
    if (num == "") {
        document.getElementById("amount-value").innerText = num;
    }
    else {
        document.getElementById("amount-value").innerText = formatMoney(num);
    }
}
function formatMoney(num) {
    var n = Number(num)
    return "$" + n.toLocaleString("en-US");
}
function removeMoneyFormat(num) {
    return Number(num.replace(/\$|,/g, ""));
}

